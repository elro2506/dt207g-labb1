<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title></title>
  <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
   <h1>Mina kurser - ett CV</h1> 
   <nav>
    <a href="/">Startsida</a>
    <a href="/courses/add">Lägg till kurser</a>
    <a href="/about">Om sidan</a>
   </nav>

   <% if (courses.length === 0) { %>
    <p>Inga kurser finns.</p>
     <% } else { %>

<table>
    <thead>
        <tr>
            <th>Kurskod</th>
            <th>Kurskod</th>
            <th>Kursplan</th>
            <th>Progression</th>
            <th>Radera</th>
        </tr>
       </thead>  
    <tbody>
<% courses.forEach(course => { %>
    <tr>
        <td><%= course.coursecode %></td>
        <td><%= course.coursename %></td>
        <td>
            <a href="<%= course.syllabus %>">Kursplan</a>
        </td>
        <td><%= course.progression %></td>
        <td>
           <a href="/delete/<%= course.id %>">Radera</a> 
        </td>
    </tr>
<% }) %>
    </tbody>
</table>
<% } %>

</body>
</html>
